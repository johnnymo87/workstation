# Nix
result
result-*
.direnv/

# Secrets (encrypted files are OK, but not decrypted)
secrets/*.dec.*

# Editor
*.swp
*~
.nvim.lua

# beads has its own .beads/.gitignore that correctly excludes the DB,
# sockets, and daemon files while keeping issues.jsonl tracked. We do
# NOT blanket-ignore .beads/ here, because that would also hide the
# JSONL source-of-truth which IS supposed to be committed.

# OpenCode user configuration (managed per-machine)
.opencode/*
!.opencode/skills/
session-ses_*.md

# Worktrees
.worktrees/

# Python
__pycache__/
*.pyc
*.pyo
