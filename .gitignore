# Nix
result
result-*
.direnv/

# Secrets (encrypted files are OK, but not decrypted)
secrets/*.dec.*

# Editor
*.swp
*~
.nvim.lua

# beads has its own .beads/.gitignore that correctly excludes the DB,
# sockets, daemon files, and JSONL exports. We do NOT blanket-ignore
# .beads/ here so that config.yaml and other non-ignored config files
# remain tracked, while data files are kept git-free.

# OpenCode user configuration (managed per-machine)
.opencode/*
!.opencode/skills/
session-ses_*.md

# Worktrees
.worktrees/

# Python
__pycache__/
*.pyc
*.pyo
