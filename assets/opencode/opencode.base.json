{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "*": "allow",
    "external_directory": {
      "/tmp/*": "allow"
    }
  },
  "tools": {
    "slack_*": false
  },
  "agent": {
    "slack": {
      "tools": {
        "slack_*": true
      }
    }
  },
  "plugin": [
    "opencode-beads",
    "@ex-machina/opencode-anthropic-auth"
  ],
  "lsp": {
    "kotlin-ls": {
      "disabled": true
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "chrome-devtools-9222": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://localhost:9222"
      ],
      "enabled": false
    },
    "chrome-devtools-9223": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://localhost:9223"
      ],
      "enabled": false
    }
  }
}
