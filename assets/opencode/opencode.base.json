{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "*": "allow",
    "external_directory": {
      "/tmp/*": "allow"
    }
  },
  "tools": {
    "slack_*": false
  },
  "agent": {
    "slack": {
      "tools": {
        "slack_*": true
      }
    }
  },
  "plugin": [
    "opencode-beads"
  ],
  "mcp": {
    "playwright-9222": {
      "type": "local",
      "command": [
        "playwright-mcp",
        "--cdp-endpoint",
        "http://localhost:9222",
        "--caps",
        "vision,devtools"
      ],
      "enabled": false
    },
    "playwright-9223": {
      "type": "local",
      "command": [
        "playwright-mcp",
        "--cdp-endpoint",
        "http://localhost:9223",
        "--caps",
        "vision,devtools"
      ],
      "enabled": false
    }
  }
}
