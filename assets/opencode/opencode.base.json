{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "permission": {
    "*": "allow",
    "question": "deny",
    "external_directory": {
      "/tmp/*": "allow"
    }
  },
  "tools": {
    "slack_*": false,
    "slack-ro_*": false
  },
  "agent": {
    "build": {
      "variant": "high",
      "permission": {
        "question": "allow"
      }
    },
    "plan": {
      "variant": "high",
      "permission": {
        "question": "allow"
      }
    }
  },
  "plugin": [
    "opencode-beads",
    "@ex-machina/opencode-anthropic-auth"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "chunkTimeout": 600000
      },
      "models": {
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "high"
          }
        },
        "claude-fable-5": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "high"
          }
        }
      }
    },
    "openai": {
      "options": {
        "chunkTimeout": 600000
      },
      "models": {
        "gpt-5.5": {
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5
          },
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ]
          }
        }
      }
    },
    "google-vertex": {
      "options": {
        "chunkTimeout": 600000
      }
    },
    "google-vertex-anthropic": {
      "options": {
        "chunkTimeout": 600000
      },
      "models": {
        "claude-opus-4-8@default": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "high"
          }
        },
        "claude-fable-5@default": {
          "id": "claude-fable-5@default",
          "name": "Claude Fable 5",
          "family": "claude-fable",
          "release_date": "2026-06-09",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": false,
          "cost": {
            "input": 10,
            "output": 50,
            "cache_read": 1,
            "cache_write": 12.5
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "high"
          }
        }
      }
    }
  },
  "lsp": {
    "kotlin-ls": {
      "disabled": true
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "chrome-devtools-9222": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://localhost:9222"
      ],
      "enabled": false
    },
    "chrome-devtools-9223": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://localhost:9223"
      ],
      "enabled": false
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    }
  }
}
