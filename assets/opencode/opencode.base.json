{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "permission": {
    "*": "allow",
    "external_directory": {
      "/tmp/*": "allow"
    }
  },
  "tools": {
    "slack_*": false,
    "slack-ro_*": false
  },
  "agent": {
    "build": {
      "variant": "xhigh"
    },
    "plan": {
      "variant": "xhigh"
    },
    "slack": {
      "tools": {
        "slack_*": true
      }
    }
  },
  "plugin": [
    "opencode-beads",
    "@ex-machina/opencode-anthropic-auth"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 300000,
        "chunkTimeout": 120000
      },
      "models": {
        "claude-opus-4-7": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "xhigh"
          }
        },
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "xhigh"
          }
        },
        "claude-fable-5": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "xhigh"
          }
        }
      }
    },
    "openai": {
      "options": {
        "timeout": 300000,
        "chunkTimeout": 120000
      },
      "models": {
        "gpt-5.5": {
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5
          },
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ]
          }
        }
      }
    },
    "google-vertex": {
      "options": {
        "timeout": 300000,
        "chunkTimeout": 120000
      }
    },
    "google-vertex-anthropic": {
      "options": {
        "timeout": 300000,
        "chunkTimeout": 120000
      },
      "models": {
        "claude-opus-4-7@default": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "xhigh"
          }
        },
        "claude-opus-4-8@default": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "xhigh"
          }
        },
        "claude-fable-5@default": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "xhigh"
          }
        }
      }
    }
  },
  "lsp": {
    "kotlin-ls": {
      "disabled": true
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "chrome-devtools-9222": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://localhost:9222"
      ],
      "enabled": false
    },
    "chrome-devtools-9223": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://localhost:9223"
      ],
      "enabled": false
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    }
  }
}
